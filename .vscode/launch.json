{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "test_parser_direct (browser)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test_parser_direct.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "args": ["--fetch-mode", "browser", "--keep-db", "--timeout", "30"],
            "cwd": "${workspaceFolder}",
            "env": { "PYTHONUNBUFFERED": "1" },
            "justMyCode": false
        },
        {
            "name": "test_parser_direct (browser + show)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test_parser_direct.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "args": ["--fetch-mode", "browser", "--show-browser", "--keep-db", "--timeout", "30"],
            "cwd": "${workspaceFolder}",
            "env": { "PYTHONUNBUFFERED": "1" },
            "justMyCode": false
        },
        {
            "name": "test_parser_direct (http)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test_parser_direct.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "args": ["--fetch-mode", "http", "--keep-db"],
            "cwd": "${workspaceFolder}",
            "env": { "PYTHONUNBUFFERED": "1" },
            "justMyCode": false
        },
        {
            "name": "test_parser_direct (custom url)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test_parser_direct.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "args": ["--fetch-mode", "browser", "--keep-db", "--url", "https://jianyangshi.58.com/shengyizr/"],
            "cwd": "${workspaceFolder}",
            "env": { "PYTHONUNBUFFERED": "1" },
            "justMyCode": false
        },
        {
            "name": "dev.py (前后端联调)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dev.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "justMyCode": false
        },
        {
            "name": "dev.py (DEBUG 日志)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dev.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "args": ["--log-level", "DEBUG"],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "justMyCode": false
        },
        {
            "name": "main.py (http + serve)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "args": ["--serve", "--fetch-mode", "http"],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "justMyCode": false
        }
    ]
}
